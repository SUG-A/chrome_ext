{
  "manifest_version": 3,
  "name": "Alarm Setter",
  "version": "1.1",
  "description": "esmのカレンダーを表示しながらボタンを押すと、アラームを追加できます。",
  "options_page": "options.html",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "activeTab",
    "system.display"
  ],
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  }
}